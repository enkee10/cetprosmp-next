13:I[6088,["7945","static/chunks/7945-6e6251a174ca16b3.js","3360","static/chunks/3360-ff34ff5925ba143b.js","9891","static/chunks/9891-63f738447f7b093c.js","6640","static/chunks/6640-6fb4d673b9b068c9.js","8630","static/chunks/8630-88a4889f795ea357.js","7338","static/chunks/7338-1f82e2b21f306887.js","3120","static/chunks/app/(aplicacion)/publicaciones/noticias/page-cd872dc96d9f3d00.js"],"default"]
