rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: comentarios
    // Document ID: comentarioId
    // Fields:
    //   - id: string (required, immutable) - Must equal comentarioId.
    //   - postId: string (required, immutable, 1..40) - Data Connect post id stored as text.
    //   - parentId: string|null (required, immutable, <=80) - Null for root comments.
    //   - nivel: number (required, immutable, 0 or 1) - Root comment or one reply level.
    //   - texto: string (required, 1..2000) - Comment body.
    //   - autorUid: string (required, immutable) - Firebase Auth UID.
    //   - autorNombre: string (required, immutable, 1..80) - Denormalized public display name.
    //   - autorFoto: string|null (required, immutable, <=500) - Denormalized public photo URL.
    //   - estado: string (required) - visible, pendiente, oculto, eliminado.
    //   - creadoEn: timestamp (required, immutable) - Creation timestamp.
    //   - actualizadoEn: timestamp (required) - Last update timestamp.
    //   - moderadoPorUid: string|null (required, <=128) - Moderator UID when moderated.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isModerator() {
      return isAuthenticated()
        && request.auth.token.level is number
        && request.auth.token.level >= 300;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isRecent(time) {
      return time is timestamp
        && time > request.time - duration.value(5, 'm')
        && time <= request.time;
    }

    function isValidUrlOrNull(value) {
      return value == null
        || (value is string
          && value.size() <= 500
          && (value.matches("^https://.*") || value.matches("^http://.*")));
    }

    function isValidOptionalUid(value) {
      return value == null || (value is string && value.size() > 0 && value.size() <= 128);
    }

    function validCommentFields() {
      return [
        'id',
        'postId',
        'parentId',
        'nivel',
        'texto',
        'autorUid',
        'autorNombre',
        'autorFoto',
        'estado',
        'creadoEn',
        'actualizadoEn',
        'moderadoPorUid',
      ];
    }

    function isValidComment(commentId) {
      return hasRequiredFields(validCommentFields())
        && hasOnlyAllowedFields(validCommentFields())
        && request.resource.data.id is string
        && request.resource.data.id == commentId
        && request.resource.data.id.size() > 0
        && request.resource.data.id.size() <= 80
        && request.resource.data.postId is string
        && request.resource.data.postId.size() > 0
        && request.resource.data.postId.size() <= 40
        && (request.resource.data.parentId == null
          || (request.resource.data.parentId is string
            && request.resource.data.parentId.size() > 0
            && request.resource.data.parentId.size() <= 80))
        && request.resource.data.nivel is number
        && request.resource.data.nivel in [0, 1]
        && request.resource.data.texto is string
        && request.resource.data.texto.size() > 0
        && request.resource.data.texto.size() <= 2000
        && request.resource.data.autorUid is string
        && request.resource.data.autorUid == request.auth.uid
        && request.resource.data.autorUid.size() > 0
        && request.resource.data.autorUid.size() <= 128
        && request.resource.data.autorNombre is string
        && request.resource.data.autorNombre.size() > 0
        && request.resource.data.autorNombre.size() <= 80
        && isValidUrlOrNull(request.resource.data.autorFoto)
        && request.resource.data.estado in ['visible', 'pendiente', 'oculto', 'eliminado']
        && request.resource.data.creadoEn is timestamp
        && request.resource.data.actualizadoEn is timestamp
        && isValidOptionalUid(request.resource.data.moderadoPorUid);
    }

    function isRootComment() {
      return request.resource.data.nivel == 0
        && request.resource.data.parentId == null;
    }

    function isReplyToRootComment() {
      return request.resource.data.nivel == 1
        && request.resource.data.parentId is string
        && exists(/databases/$(database)/documents/comentarios/$(request.resource.data.parentId))
        && get(/databases/$(database)/documents/comentarios/$(request.resource.data.parentId)).data.nivel == 0
        && get(/databases/$(database)/documents/comentarios/$(request.resource.data.parentId)).data.postId == request.resource.data.postId;
    }

    function immutableCommentFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'id',
        'postId',
        'parentId',
        'nivel',
        'autorUid',
        'autorNombre',
        'autorFoto',
        'creadoEn',
      ]);
    }

    function authorEditOnly() {
      return isOwner(resource.data.autorUid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['texto', 'actualizadoEn'])
        && request.resource.data.estado == resource.data.estado
        && request.resource.data.moderadoPorUid == resource.data.moderadoPorUid;
    }

    function moderatorEditOnly() {
      return isModerator()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'texto',
          'estado',
          'actualizadoEn',
          'moderadoPorUid',
        ])
        && request.resource.data.moderadoPorUid == request.auth.uid;
    }

    match /comentarios/{comentarioId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && isValidComment(comentarioId)
        && request.resource.data.estado in ['visible', 'pendiente']
        && request.resource.data.moderadoPorUid == null
        && isRecent(request.resource.data.creadoEn)
        && isRecent(request.resource.data.actualizadoEn)
        && (isRootComment() || isReplyToRootComment());

      allow update: if isAuthenticated()
        && isValidComment(comentarioId)
        && immutableCommentFieldsUnchanged()
        && isRecent(request.resource.data.actualizadoEn)
        && (authorEditOnly() || moderatorEditOnly());

      allow delete: if isModerator();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
