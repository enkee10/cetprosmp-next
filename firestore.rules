rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow any authenticated user to read any document
    // Allow only users with level >= 600 (superusers) to write to any document
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.level >= 600;
    }
  }
}
