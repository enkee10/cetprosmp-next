{
    "name": "functions",
    "scripts": {
        "lint": "set ESLINT_USE_FLAT_CONFIG=false&& eslint .",
        "build": "tsc",
        "build:watch": "tsc --watch",
        "serve": "npm run build && npx -y firebase-tools@latest emulators:start --only auth,functions,firestore,storage,dataconnect",
        "shell": "npm run build && npx -y firebase-tools@latest functions:shell",
        "start": "npm run shell",
        "deploy": "npm run build && npx -y firebase-tools@latest deploy --only functions",
        "logs": "npx -y firebase-tools@latest functions:log"
    },
    "engines": {
        "node": "22"
    },
    "main": "lib/index.js",
    "dependencies": {
        "@dataconnect/admin-generated": "file:src/dataconnect-admin-generated",
        "firebase-admin": "^13.10.0",
        "firebase-functions": "^7.2.5",
        "googleapis": "^142.0.0",
        "mi-frontend": "file:..",
        "sharp": "^0.35.3"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^5.12.0",
        "@typescript-eslint/parser": "^5.12.0",
        "eslint": "^8.9.0",
        "eslint-config-google": "^0.14.0",
        "eslint-plugin-import": "^2.25.4",
        "typescript": "^5.7.3"
    },
    "private": true
}
