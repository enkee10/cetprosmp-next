{
  "name": "mi-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "emulators:start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-firebase-emulators.ps1",
    "emulators:safe": "powershell -ExecutionPolicy Bypass -File ./scripts/start-firebase-emulators.ps1 -ExportDir ./data -Only auth,functions,firestore,storage,dataconnect",
    "emulators:full": "powershell -ExecutionPolicy Bypass -File ./scripts/start-firebase-emulators.ps1 -Full",
    "emulators:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-firebase-emulators.ps1",
    "auth:oob:verify-latest": "node scripts/auth-oob.mjs verify-latest",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy:full": "set FUNCTIONS_DISCOVERY_TIMEOUT=60&& npx -y firebase-tools@latest deploy --project cetprosmp-2026 --force",
    "functions:invoker:public": "node scripts/functions-invoker-public.mjs",
    "diagram:gql": "node scripts/gql-to-mermaid.cjs",
    "diagram:gql:watch": "node scripts/gql-to-mermaid.cjs --watch"
  },
  "dependencies": {
    "@dataconnect/admin-generated": "file:src/dataconnect-admin-generated",
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.2.0",
    "@mui/material-nextjs": "^9.0.1",
    "@mui/x-data-grid": "^8.27.3",
    "@react-oauth/google": "^0.12.2",
    "@tinymce/tinymce-react": "^6.3.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/extension-table": "^3.26.0",
    "@tiptap/extension-table-cell": "^3.26.0",
    "@tiptap/extension-table-header": "^3.26.0",
    "@tiptap/extension-table-row": "^3.26.0",
    "@tiptap/extension-underline": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "axios": "^1.10.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.9.0",
    "firebase-functions": "^7.2.5",
    "next": "^15.5.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "swiper": "^12.1.2",
    "tinymce": "^8.6.0",
    "tinymce-i18n": "^26.6.8",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "typescript": "^5"
  }
}
