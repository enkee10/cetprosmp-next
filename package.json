{
  "name": "mi-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "dev:local": "npx -y concurrently \"npm run emulators:start\" \"npm run dev\"",
    "dev:dc": "npx firebase-tools emulators:start --only dataconnect --project demo-cetprosmp --config firebase.dataconnect.local.json",
    "emulators:start": "npx -y firebase-tools@latest emulators:start --project cetprosmp-2026 --import=./exportedData --export-on-exit=./exportedData",
    "emulators:export": "npx -y firebase-tools@latest emulators:export ./exportedData --project cetprosmp-2026",
    "auth:oob:list": "node scripts/auth-oob.mjs list",
    "auth:oob:open": "node scripts/auth-oob.mjs open",
    "auth:oob:latest": "node scripts/auth-oob.mjs latest",
    "auth:oob:verify": "node scripts/auth-oob.mjs verify",
    "auth:oob:verify-latest": "node scripts/auth-oob.mjs verify-latest",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@dataconnect/admin-generated": "file:src/dataconnect-admin-generated",
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.2.0",
    "@mui/material-nextjs": "^9.0.1",
    "@mui/x-data-grid": "^8.27.3",
    "@react-oauth/google": "^0.12.2",
    "axios": "^1.10.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.9.0",
    "firebase-functions": "^7.2.5",
    "next": "^15.5.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "swiper": "^12.1.2",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "typescript": "^5"
  }
}
